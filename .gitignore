# ==========================================
# On Board NZ Dairy - .gitignore
# ==========================================

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
# Keep .vscode/extensions.json (it's a shared recommendation),
# but ignore per-user settings and workspace state.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# --- Node / MERN (for when you add the backend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# --- Environment variables (NEVER commit secrets) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Build output ---
dist/
build/
out/
.next/
.vercel/

# --- Logs ---
logs/
*.log

# --- Misc ---
.cache/
coverage/
